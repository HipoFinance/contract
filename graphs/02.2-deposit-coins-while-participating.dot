digraph {
    label="staker deposits 10 GRAM to receive ~10 hGRAM, after the current round is finalized"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    staker [ color=2 ]
    wallet, bill [ color=3 ]
    treasury [ color=4 ]
    parent, collection [ color=5 ]

    /* Relationships */
    staker -> treasury [ label="1\l op::deposit_coins\l 10.10 GRAM\l" ]
    treasury -> parent [ label="2\l op::proxy_save_coins\l 0.02 GRAM\l coins: 10\l" ]
    parent -> wallet [ label="3\l op::save_coins\l 0.01 GRAM\l coins: 10\l" ]
    treasury -> collection [ label="4\l op::mint_bill\l 0.07 GRAM\l coins: 10\l" ]
    collection -> bill [ label="5\l op::assign_bill\l 0.06 GRAM\l coins: 10\l" ]
    bill -> staker [ label="6\l op::ownership_assigned\l 0.01 GRAM\l" ]

    /* Ranks */
    { rank=min staker }
}
