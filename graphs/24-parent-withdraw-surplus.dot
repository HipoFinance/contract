digraph {
    label="the current governor withdraws surplus GRAM value of parent"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    governor [ color=2 ]
    treasury [ color=4 ]
    parent [ color=5 ]

    /* Relationships */
    governor -> treasury [ label="1\l op::proxy_withdraw_surplus\l 0.10 GRAM\l" ]
    treasury -> parent [ label="2\l op::withdraw_surplus\l 0.09 GRAM\l"]
    parent -> governor [ label="3\l op::gas_excess\l 20.08 GRAM\l" ]

    /* Ranks */
    { rank=min governor }
}
