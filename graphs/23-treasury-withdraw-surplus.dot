digraph {
    label="the current governor withdraws surplus GRAM value of treasury"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    governor [ color=2 ]
    treasury [ color=4 ]

    /* Relationships */
    governor -> treasury [ label="1\l op::withdraw_surplus\l 0.10 GRAM\l" ]
    treasury -> governor [ label="2\l op::gas_excess\l 20.09 GRAM\l" ]

    /* Ranks */
    { rank=min governor }
    { rank=max treasury }
}
