digraph {
    label="the current halter sets the instant-mint flag"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    halter [ color=2 ]
    treasury [ color=4 ]

    /* Relationships */
    halter -> treasury [ label="1\l op::set_instant_mint\l 0.10 GRAM\l" ]
    treasury -> halter [ label="2\l op::gas_excess\l 0.09 GRAM\l" ]

    /* Ranks */
    { rank=min halter }
    { rank=max treasury }
}
