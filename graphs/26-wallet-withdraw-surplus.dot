digraph {
    label="staker withdraws surplus GRAM value of wallet"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    staker [ color=2 ]
    wallet [ color=3 ]

    /* Relationships */
    staker -> wallet [ label="1\l op::withdraw_surplus\l 0.10 GRAM\l" ]
    wallet -> staker [ label="2\l op::gas_excess\l 0.14 GRAM\l" ]

    /* Ranks */
    { rank=min staker }
    { rank=max wallet }
}
