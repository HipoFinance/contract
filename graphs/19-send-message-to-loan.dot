digraph {
    label="the current halter sends any message to a loan"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    halter [ color=2 ]
    treasury [ color=4 ]
    loan [ color=5 ]

    /* Relationships */
    halter -> treasury [ label="1\l op::send_message_to_loan\l 0.10 GRAM\l" ]
    treasury -> loan [ label="2\l 0.9 GRAM\l" ]

    /* Ranks */
    { rank=min halter }
    { rank=max treasury }
}
