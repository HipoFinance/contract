digraph {
    label="the current governor sets the content"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    governor [ color=2 ]
    treasury [ color=4 ]
    parent [ color=5 ]

    /* Relationships */
    governor -> treasury [ label="1\l op::proxy_set_content\l 0.10 GRAM\l" ]
    treasury -> parent [ label="2\l op::set_content\l 0.09 GRAM\l"]
    parent -> governor [ label="3\l op::gas_excess\l 0.08 GRAM\l" ]

    /* Ranks */
    { rank=min governor }
}
