digraph {
    label="the current halter retries recovering stakes"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    halter [ color=2 ]
    treasury [ color=4 ]

    /* Relationships */
    halter -> treasury [ label="1\l op::retry_recover_stakes\l 0.10 GRAM\l" ]
    treasury -> treasury [ label="2\l op::recover_stakes\l 0.9 GRAM\l" ]

    /* Ranks */
    { rank=min halter }
    { rank=max treasury }
}
