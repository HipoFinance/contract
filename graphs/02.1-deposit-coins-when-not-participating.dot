digraph {
    label="staker deposits 10 GRAM to receive ~10 hGRAM, when there is no active round"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    staker [ color=2 ]
    wallet [ color=3 ]
    treasury [ color=4 ]
    parent [ color=5 ]

    /* Relationships */
    staker -> treasury [ label="1\l op::deposit_coins\l 10.10 GRAM\l" ]
    treasury -> parent [ label="2\l op::proxy_tokens_minted\l 0.09 GRAM\l tokens: ~10\l coins: 10\l" ]
    parent -> wallet [ label="3\l op::tokens_minted\l 0.08 GRAM\l tokens: ~10\l coins: 10\l" ]
    wallet -> staker [ label="4\l op::transfer_notification\l 0.07 GRAM\l tokens: ~10\l" ]

    /* Ranks */
    { rank=min staker }
}
