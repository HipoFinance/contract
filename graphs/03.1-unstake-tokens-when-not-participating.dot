digraph {
    label="staker unstakes 10 hGRAM to receive ~10 GRAM, when there is no active round"
    node [ colorscheme=pastel19 style=filled ]

    /* Entities */
    staker [ color=2 ]
    wallet [ color=3 ]
    treasury [ color=4 ]
    parent [ color=5 ]

    /* Relationships */
    staker -> wallet [ label="1\l op::unstake_tokens\l 0.10 GRAM\l tokens: 10\l" ]
    wallet -> parent [ label="2\l op::proxy_reserve_tokens\l 0.09 GRAM\l tokens: 10\l" ]
    parent -> treasury [ label="3\l op::reserve_tokens\l 0.08 GRAM\l tokens: 10\l" ]
    treasury -> parent [ label="4\l op::proxy_tokens_burned\l 10.07 GRAM\l tokens: 10\l coins: ~10\l" ]
    parent -> wallet [ label="5\l op::tokens_burned\l 10.06 GRAM\l tokens: 10\l coins: ~10\l" ]
    wallet -> staker [ label="6\l op::withdrawal_notification\l 10.05 GRAM\l tokens: 10\l coins: ~10\l" ]

    /* Ranks */
    { rank=min staker }
}
